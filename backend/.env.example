# ── Backend Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys

# Alpha Vantage — free API key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ExchangeRate-API — free tier at https://www.exchangerate-api.com
# Free plan: 1,500 requests/month (more than enough for daily use)
EXCHANGERATE_KEY=your_exchangerate_api_key_here

# Brent oil via yfinance — NO KEY NEEDED (free)
